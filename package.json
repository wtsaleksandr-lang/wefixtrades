{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "dev:linux": "kill $(cat /tmp/wft-server.pid 2>/dev/null) 2>/dev/null; sleep 0.5; CHOKIDAR_USEPOLLING=1 NODE_ENV=development tsx server/index.ts & echo $! > /tmp/wft-server.pid && wait",
    "build": "tsx script/build.ts",
    "test:build-smoke": "tsx tests/build-smoke.test.ts",
    "start": "cross-env NODE_ENV=production node dist/index.cjs",
    "check": "tsc",
    "check:copilot-forms": "node scripts/check-copilot-forms.mjs",
    "check:hardcoded-colors": "node scripts/check-hardcoded-colors.mjs",
    "check:layout-rules": "node scripts/check-layout-rules.mjs",
    "check:migrations": "node scripts/check-migrations-safe.mjs",
    "check:migration-safety": "node scripts/check-migration-safety.mjs",
    "check:no-db-push-in-prod": "node scripts/check-no-db-push-in-prod.mjs",
    "check:no-mp-secret-in-client": "node scripts/check-no-mp-secret-in-client.mjs",
    "check:schema-drift": "node scripts/check-schema-drift.mjs",
    "check:database-url": "node scripts/check-database-url.mjs",
    "smoke:quick": "tsx script/smoke.ts",
    "test:formula": "tsx scripts/check-formula.ts",
    "audit": "npm run build && playwright test --config audit.config.ts",
    "audit:update": "npm run build && playwright test --config audit.config.ts --update-snapshots",
    "db:push:dev": "node scripts/check-not-prod.mjs && drizzle-kit push --config=scripts/db/drizzle.config.dev.ts",
    "db:generate:dev": "node scripts/check-not-prod.mjs && drizzle-kit generate --config=scripts/db/drizzle.config.dev.ts",
    "db:studio:dev": "node scripts/check-not-prod.mjs && drizzle-kit studio --config=scripts/db/drizzle.config.dev.ts",
    "check:no-prod-drizzle-config": "node scripts/check-no-prod-drizzle-config.mjs",
    "check:drizzle-kit-is-dev-dep": "node scripts/check-drizzle-kit-is-dev-dep.mjs",
    "check:no-silent-catch": "node scripts/check-no-silent-catch.mjs",
    "test:e2e": "npx playwright test tests/e2e/audit-flow.spec.ts",
    "test:smoke": "npx playwright test tests/e2e/smoke.spec.ts",
    "test:crm": "npx playwright test tests/e2e/admin-crm/",
    "test:crm:smoke": "npx playwright test tests/e2e/admin-crm/admin-crm.smoke.spec.ts",
    "test:crm:e2e": "npx playwright test tests/e2e/admin-crm/admin-crm.e2e.spec.ts",
    "test:crm:regression": "npx playwright test tests/e2e/admin-crm/admin-crm.regression.spec.ts",
    "seed:test-portal-client": "tsx scripts/seed-test-portal-client.ts",
    "record:google-verification": "npx playwright test --config scripts/google-verification/playwright.config.ts",
    "thumbnails": "tsx scripts/generate-template-thumbnails.ts",
    "previews:free-tools": "tsx scripts/generate-free-tool-previews.ts",
    "healthz:check": "node -e \"fetch(process.env.HEALTHZ_URL||'http://127.0.0.1:5000/api/healthz').then(r=>r.json().then(b=>{console.log(JSON.stringify(b,null,2));process.exit(b.status==='ok'?0:1)}))\"",
    "smoke:critical": "playwright test --config=smoke.config.ts",
    "post-deploy:verify": "node scripts/post-deploy-verify.mjs",
    "deploy:watchdog": "node scripts/deploy/rollback-monitor.mjs",
    "lh:assert": "npx --yes -p @lhci/cli@0.14.x lhci autorun --config=lighthouserc.cjs"
  },

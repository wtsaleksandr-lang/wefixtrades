# ────────────────────────────────────────────────────────────────────
# WeFixTrades — example environment configuration
#
# This file lists every env var the app reads. Copy to `.env` and fill
# in the values for each integration you need. Variables you leave
# unset cause the corresponding feature to be disabled (or, for
# webhook secrets, that webhook to be rejected in production).
#
# DO NOT commit a real .env to git.
# ────────────────────────────────────────────────────────────────────


# ─── App / Core ─────────────────────────────────────────────────────
NODE_ENV=development               # development | production | test
PORT=5000
APP_URL=                           # Public base URL (used in emails, OAuth callbacks)
APP_PUBLIC_URL=                    # Same as APP_URL — used by SocialSync media service
BASE_URL=                          # Optional override for outbound links
LOG_LEVEL=                         # `debug` enables verbose API response logging
GIT_BRANCH=                        # Optional — surfaced in admin diagnostics
REPLIT_DEV_DOMAIN=                 # Auto-set on Replit; do not set manually


# ─── Database ───────────────────────────────────────────────────────
DATABASE_URL=                      # postgres://user:pass@host:5432/dbname


# ─── Security / Session ─────────────────────────────────────────────
SESSION_SECRET=                    # Long random string (>=32 chars)
TOKEN_ENCRYPTION_KEY=              # 64-hex-char or arbitrary string for AES-256-GCM
                                   #   (encrypts OAuth tokens + WordPress app passwords at rest)
UNSUBSCRIBE_SECRET=                # HMAC key for one-click unsubscribe tokens
BILLING_PORTAL_SECRET=             # HMAC key for billing portal magic links


# ─── Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                 # sk_live_... or sk_test_...
STRIPE_BILLING_WEBHOOK_SECRET=     # whsec_... — REQUIRED in production
STRIPE_PRICE_QQ_SOLO_MONTHLY=      # price_... QuoteQuick Solo monthly plan
STRIPE_PRICE_QQ_SOLO_ANNUAL=       # price_... QuoteQuick Solo annual plan
STRIPE_PRICE_QQ_BUSINESS_MONTHLY=  # price_... QuoteQuick Business monthly plan
STRIPE_PRICE_QQ_BUSINESS_ANNUAL=   # price_... QuoteQuick Business annual plan


# ─── SMTP / SendGrid (transactional email) ──────────────────────────
SMTP_HOST=                         # e.g. smtp.sendgrid.net
SMTP_PORT=                         # 587 (STARTTLS) or 465 (TLS)
SMTP_USER=                         # SendGrid: apikey
SMTP_PASS=                         # SendGrid API key
SMTP_FROM=                         # From: header (e.g. "WeFixTrades <noreply@wefixtrades.co.uk>")
ADMIN_EMAIL=                       # Default admin notification recipient
INTERNAL_LEAD_EMAIL=               # Recipient for inbound lead notifications
MAPGUARD_ALERT_EMAIL=              # Alert inbox for MapGuard incidents
SOCIALSYNC_ALERT_EMAIL=            # Alert inbox for SocialSync OAuth/publish failures
SOCIALSYNC_ALERT_WEBHOOK=          # Optional Slack/webhook URL for SocialSync alerts
EMAIL_CHARTS_DIR=                  # Optional override for email-chart cache directory


# ─── Twilio (SMS / WhatsApp) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=                # AC...
TWILIO_AUTH_TOKEN=                 # Required for inbound webhook signature validation
TWILIO_FROM_NUMBER=                # +44... — preferred SMS sender
TWILIO_PHONE_NUMBER=               # Legacy alias for TWILIO_FROM_NUMBER (kept for compat)
TWILIO_WHATSAPP_NUMBER=            # whatsapp:+44... — falls back to FROM_NUMBER if unset


# ─── Vapi (voice assistant) ─────────────────────────────────────────
VAPI_API_KEY=                      # Server-side Vapi API key
VAPI_PUBLIC_KEY=                   # Client-side key for browser voice demo
VAPI_ASSISTANT_ID=                 # Default assistant id
VAPI_PHONE_NUMBER_ID=              # Vapi phone number id (for inbound calls)
VAPI_WEBHOOK_SECRET=               # HMAC-SHA256 secret — REQUIRED in production
VAPI_SERVER_URL=                   # Public URL Vapi calls back to (your APP_URL)
VAPI_WFT_VOICE_ID=                 # Optional ElevenLabs voice id override


# ─── Anthropic Claude ───────────────────────────────────────────────
ANTHROPIC_API_KEY=                 # Required for AI assistant, audits, ops engine
CLAUDE_MODEL=                      # Optional override (default: claude-haiku-4-5-20251001)


# ─── OpenAI ─────────────────────────────────────────────────────────
OPENAI_API_KEY=                    # Canonical — required for image gen + AI fallback chat
AI_INTEGRATIONS_OPENAI_API_KEY=    # Legacy alias (auto-falls-back; rename to OPENAI_API_KEY)
AI_INTEGRATIONS_OPENAI_BASE_URL=   # Optional override (e.g. Azure proxy)
IMAGE_MODEL=                       # Optional override (default: gpt-image-1)
IMAGE_SIZE=                        # Optional override (default: 1024x1024)
IMAGE_QUALITY=                     # Optional override (default: high)
IMAGE_API_BASE_OVERRIDE=           # Test-only — routes image API to a mock (NODE_ENV != production)


# ─── Google APIs ────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=               # Places + Place Details (for audit + MapGuard)
PAGESPEED_API_KEY=                 # PageSpeed Insights (for audit)
GOOGLE_OAUTH_CLIENT_ID=            # General Google OAuth client (legacy GBP path)
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_BUSINESS_CLIENT_ID=         # SocialSync GBP OAuth client (separate config)
GOOGLE_BUSINESS_CLIENT_SECRET=
GOOGLE_BUSINESS_REDIRECT_URI=
GBP_API_BASE_OVERRIDE=             # Test-only override for GBP API base
GBP_POST_API_BASE_OVERRIDE=        # Test-only override for GBP post API base


# ─── Meta (Facebook + Instagram Graph) ──────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=             # https://APP_URL/api/socialsync/oauth/facebook/callback
FB_GRAPH_API_BASE_OVERRIDE=        # Test-only override
IG_GRAPH_API_BASE_OVERRIDE=        # Test-only override
CONTENTFLOW_FB_INSIGHTS=           # Feature flag: 1/0 — enable FB insights pull
CONTENTFLOW_IG_INSIGHTS=           # Feature flag: 1/0 — enable IG insights pull
CONTENTFLOW_REAL_API_SMOKE=        # Feature flag: 1/0 — Sprint 19 real-API smoke


# ─── Cloudflare R2 (image storage) ──────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=                       # https://<accountid>.r2.cloudflarestorage.com
R2_PUBLIC_URL=                     # Custom CDN domain pointing at the bucket


# ─── Outscraper (review monitoring) ─────────────────────────────────
OUTSCRAPER_API_KEY=


# ─── DataForSEO (SEO audits) ────────────────────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=


# ─── Serper (rank tracking) ─────────────────────────────────────────
SERPER_API_KEY=


# ─── QuickChart (email charts) ──────────────────────────────────────
QUICKCHART_API_KEY=


# ─── Outbound email outreach (Instantly / Smartlead) ────────────────
INSTANTLY_API_KEY=
SMARTLEAD_API_KEY=                 # Adapter shipped but V1 unimplemented
OUTREACH_WEBHOOK_SECRET=           # Shared secret — REQUIRED in production


# ─── WordPress publishing ──────────────────────────────────────────
# WordPress credentials are stored per-client in the database, encrypted with
# TOKEN_ENCRYPTION_KEY (above). No global env var is needed for normal use.
SOCIALSYNC_MEDIA_DIR=              # Optional override for local media cache


# ─── Other webhook secrets ──────────────────────────────────────────
QQP_WEBHOOK_SECRET=                # QuoteQuick partner webhook shared secret


# ─── Feature flags / operator toggles ───────────────────────────────
ALLOW_REAL_POSTS=                  # 1 to allow ContentFlow to actually publish (else dry-run)
DRY_RUN=                           # 1 forces all outbound effects to be simulated
DEV_TOOLS_ENABLED=                 # 1 enables /api/__dev/* helper routes (NODE_ENV != production)
ADMIN_TOOLS_ENABLED=               # 1 enables admin-only diagnostic routes
EMAIL_TEST_SIMULATE_SUCCESS=       # 1 makes test emails pretend success without sending
REPURPOSER_AI_STUB=                # 1 forces deterministic stub output instead of LLM
REPURPOSER_AUTO_FIRE=              # 1 auto-triggers the repurposer worker after generation


# ─── Test / smoke ───────────────────────────────────────────────────
TEST_ADMIN_EMAIL=                  # Used by integration tests
TEST_ADMIN_PASSWORD=               # Used by integration tests
# SMOKE_* — populated only when running scripts/contentflow-real-smoke.* tooling.
# See docs/contentflow-real-api-smoke.md for the full list.

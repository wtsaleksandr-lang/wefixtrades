# ─── Mobile App Preview (Appetize.io) ───────────────────────────
# publicKey from appetize.io after uploading the APK / IPA.
# Surfaces the "App Preview" tab inside /admin/crm/tradeline-ops.
# Non-secret — these go into the iframe URL.
# Free tier: 100 min/month — https://appetize.io/signup
# VITE_APPETIZE_PUBLIC_KEY_ANDROID=
# VITE_APPETIZE_PUBLIC_KEY_IOS=

# ─── Core / Server ───────────────────────────────────────────────
# Node environment: development | production
NODE_ENV=development

# Port the server listens on (default 5000)
# PORT=5000

# Session secret for express-session (REQUIRED in production)
SESSION_SECRET=change-me-to-a-random-string

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/wefixtrades

# Public-facing app URL (used in emails, redirects, billing portal links)
# APP_URL=https://yourdomain.com

# Public-facing URL used for asset links, email images, media URLs
# Falls back to APP_URL when not set (optional)
# APP_PUBLIC_URL=https://yourdomain.com

# Base URL for test scripts (test-stripe-flow, test-tradeline-flow)
# BASE_URL=http://localhost:5000

# Log level: debug | info (optional)
# LOG_LEVEL=info

# ─── AI / LLM ───────────────────────────────────────────────────
# Anthropic Claude API key (primary AI — audit reports, chat, etc.)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model override (optional — defaults to claude-haiku-4-5-20251001)
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# OpenAI API key (for AI-powered pricing generation)
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key_here

# OpenAI base URL override (optional — for proxies or compatible endpoints)
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# OpenAI API key (secondary — image generation, etc.)
# OPENAI_API_KEY=your_openai_api_key_here

# Gemini / Google AI Studio key (text rotator fallback after Anthropic + OpenAI).
# Either name is accepted by server/services/ai/textRotator.ts. Provision via
#   gcloud services api-keys create --api-target=service=generativelanguage.googleapis.com
# When unset, the rotator skips Gemini and falls through cleanly.
# GEMINI_API_KEY=
# GOOGLE_AI_API_KEY=

# Text provider rotation order (optional override). Default:
#   anthropic,openai,gemini
# Comma-separated subset of {anthropic, openai, gemini}. Missing names fall
# through to the default order so a partial override never drops a provider.
# AI_TEXT_PROVIDERS=anthropic,openai,gemini

# ─── Image Generation ─────────────────────────────────────────────
# Model for AI image generation (optional, default: gpt-image-1)
# IMAGE_MODEL=gpt-image-1
# Image quality: low | medium | high (optional, default: medium)
# IMAGE_QUALITY=medium
# Image size: 1024x1024 | 1024x1536 | 1536x1024 (optional, default: 1024x1024)
# IMAGE_SIZE=1024x1024
# Override base URL for image generation API (dev/test only)
# IMAGE_API_BASE_OVERRIDE=

# Image-rotator fallbacks (after OpenAI). Both unset = OpenAI-only path,
# which is the current production posture. See server/services/ai/imageRotator.ts.
# REPLICATE_API_TOKEN=your_replicate_token   # provisioned at replicate.com
# IDEOGRAM_API_KEY=your_ideogram_key         # provisioned at ideogram.ai/api

# Image provider rotation order (optional override). Default:
#   openai-image,replicate,ideogram
# AI_IMAGE_PROVIDERS=openai-image,replicate,ideogram

# ─── Video Generation (optional — ContentFlow video feature) ───
# LUMA_API_KEY=your_luma_ai_key
# RUNWAY_API_KEY=your_runway_ml_key (fallback)
# Video output (5-sec B-roll) does not match the 3-5 min script. Disabled
# until aligned. Default is false — leave unset or set to false in prod.
VIDEO_GENERATION_ENABLED=false

# ─── Stripe (Payments) ──────────────────────────────────────────
# Stripe secret key (REQUIRED — used across billing, checkout, subscriptions)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe webhook signing secrets (REQUIRED in production)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_BILLING_WEBHOOK_SECRET=whsec_your_billing_webhook_secret_here
# STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret_here

# Stripe Price IDs for QuoteQuick plans — Wave Q pricing restructure
# (May 2026). Three-tier ladder: Free (no Stripe), Pro $29/mo, Business
# $79/mo. Annual = 17% off ("two months free").
#   Pro    monthly = $29   annual = $290/yr ($24.07/mo effective)
#   Pro    annual  = $290/yr
#   Business monthly = $79  annual = $790/yr ($65.83/mo effective)
#   Business annual  = $790/yr
# Alex provisions 4 live recurring prices in Stripe and sets these in
# Doppler wefixtrades/prd. Until then, QQ subscription checkout 400s.
STRIPE_PRICE_QQ_PRO_MONTHLY=price_xxx
STRIPE_PRICE_QQ_PRO_ANNUAL=price_xxx
STRIPE_PRICE_QQ_BUSINESS_MONTHLY=price_xxx
STRIPE_PRICE_QQ_BUSINESS_ANNUAL=price_xxx
# Legacy — retained so any grandfathered Starter customers keep their
# subscription. New checkouts never reference STARTER. Can be unset once
# all legacy subs migrate or churn.
# STRIPE_PRICE_QQ_STARTER_MONTHLY=price_xxx
# STRIPE_PRICE_QQ_STARTER_ANNUAL=price_xxx

# Stripe Price IDs for API Platform (Wave AJ-3 — pricing locked).
# Five tiers, monthly + annual each. Developer tier is free (no Stripe).
# Annual = 17% off (matches QUOTEQUICK_YEARLY_DISCOUNT_PCT).
# Loyalty Starter monthly is $29 (40% off list $49) — automatically
# substituted at checkout for users with an active QuoteQuick Pro or
# Business subscription. Alex creates all 9 prices in Stripe Dashboard
# and sets these in Doppler wefixtrades/prd. Until then, the
# /api/portal/api-keys/checkout endpoint returns 503 "pricing_not_configured"
# instead of crashing.
#   Starter    monthly = $49    annual = $480/yr ($40/mo eq.)
#   Starter    loyalty = $29/mo (QQ paid only)
#   Pro        monthly = $149   annual = $1488/yr ($124/mo eq.)
#   Business   monthly = $399   annual = $3972/yr ($331/mo eq.)
#   Agency     monthly = $999   annual = $9948/yr ($829/mo eq.)
STRIPE_API_STARTER_MONTHLY_PRICE=price_xxx
STRIPE_API_STARTER_ANNUAL_PRICE=price_xxx
STRIPE_API_STARTER_LOYALTY_MONTHLY_PRICE=price_xxx
STRIPE_API_PRO_MONTHLY_PRICE=price_xxx
STRIPE_API_PRO_ANNUAL_PRICE=price_xxx
STRIPE_API_BUSINESS_MONTHLY_PRICE=price_xxx
STRIPE_API_BUSINESS_ANNUAL_PRICE=price_xxx
STRIPE_API_AGENCY_MONTHLY_PRICE=price_xxx
STRIPE_API_AGENCY_ANNUAL_PRICE=price_xxx

# Stripe Price IDs for ContentFlow standalone plans (phase2-decision #3):
# Creator $49/mo, Studio $99/mo, Agency $199/mo. Alex provisions the live
# recurring prices in Stripe and sets these in Doppler wefixtrades/prd.
# Until then, publicCheckoutRoutes falls back to the catalog stripe_price_id
# (sync-stripe.ts), then returns a clean "contact us" error.
STRIPE_CONTENTFLOW_CREATOR_PRICE=price_xxx
STRIPE_CONTENTFLOW_CREATOR_YEARLY_PRICE=price_xxx
STRIPE_CONTENTFLOW_STUDIO_PRICE=price_xxx
STRIPE_CONTENTFLOW_STUDIO_YEARLY_PRICE=price_xxx
STRIPE_CONTENTFLOW_AGENCY_PRICE=price_xxx
STRIPE_CONTENTFLOW_AGENCY_YEARLY_PRICE=price_xxx

# ─── Twilio (SMS / WhatsApp / Voice) ────────────────────────────
# SMS / WhatsApp — required for inbound + outbound messaging
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890           # canonical name
TWILIO_FROM_NUMBER=+1234567890            # legacy alias — either works
TWILIO_WHATSAPP_NUMBER=+1234567890        # optional, WhatsApp channel only

# Voice (admin dialer + mobile Voice SDK) — all four required for outbound calling
# API Key/Secret are SEPARATE from AUTH_TOKEN (Twilio Console → Account → API keys & tokens)
# APP_SID is a TwiML App whose Voice URL = https://<host>/api/twilio/voice/outbound-twiml
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your_api_key_secret
TWILIO_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Push credentials for inbound voice on mobile (optional — outbound works without)
TWILIO_PUSH_CREDENTIAL_SID_IOS=CRxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PUSH_CREDENTIAL_SID_ANDROID=CRxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook URLs to configure in Twilio Console:
#   Number "A MESSAGE COMES IN" → POST /api/twilio/inbound       (signature-verified, AI reply)
#   Number "A CALL COMES IN"    → POST /api/twilio/voice/inbound (if present) or TwiML App
#   TwiML App Voice URL         → POST /api/twilio/voice/outbound-twiml
#   TwiML App Status Callback   → POST /api/twilio/voice/status

# ─── SMTP (Email) ───────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# SendGrid Event Webhook verification key (REQUIRED for /api/email/sendgrid-webhook).
# SendGrid → Settings → Mail Settings → Event Webhook → enable "Signed Event
# Webhook Requests" and copy the verification key. Accepts either a full PEM
# or the raw base64 the dashboard surfaces. If unset, the webhook returns 503.
# SENDGRID_WEBHOOK_PUBLIC_KEY=your_sendgrid_event_webhook_public_key

# SPF / DKIM expected values for Pro-tier custom-domain verification
# (server/lib/dnsVerify.ts). Defaults assume SendGrid; override if you ever
# migrate to Postmark / Resend / Mailgun.
# SENDGRID_SPF_INCLUDE=sendgrid.net
# SENDGRID_DKIM_SELECTOR=s1._domainkey

# ─── Google Cloud (Single Project) ───────────────────────────────
# OAuth 2.0 Web Client (used by GBP review-reply + SocialSync GBP)
GOOGLE_BUSINESS_CLIENT_ID=
GOOGLE_BUSINESS_CLIENT_SECRET=
GOOGLE_BUSINESS_REDIRECT_URI=https://yourdomain.com/api/admin/crm/google/callback

# Maps/Places API key (Free Audit + MapGuard)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# PageSpeed API key (defaults to GOOGLE_MAPS_API_KEY if unset)
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Token encryption for OAuth credentials at rest
TOKEN_ENCRYPTION_KEY=  # generate: openssl rand -hex 32

# ─── Vapi Voice Integration (optional) ──────────────────────────
# VAPI_API_KEY=your_vapi_api_key_here
# VAPI_PUBLIC_KEY=your_vapi_public_key_here
# VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
# VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here
# VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here
# VAPI_SERVER_URL=https://yourdomain.com
# VAPI_WFT_VOICE_ID=your_voice_id_here

# ─── Facebook / Instagram (optional) ────────────────────────────
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_REDIRECT_URI=

# ─── SocialSync ─────────────────────────────────────────────────
# Webhook URL for SocialSync alerts (Slack/Discord/etc.) (optional)
# SOCIALSYNC_ALERT_WEBHOOK=https://hooks.slack.com/services/xxx

# Local directory for SocialSync media files (optional, has built-in default)
# SOCIALSYNC_MEDIA_DIR=./data/socialsync-media

# Override base URL for Facebook Graph API (dev/test only)
# FB_GRAPH_API_BASE_OVERRIDE=
# Override base URL for Instagram Graph API (dev/test only)
# IG_GRAPH_API_BASE_OVERRIDE=
# Override base URL for Google Business Profile posting API (dev/test only)
# GBP_POST_API_BASE_OVERRIDE=
# Override base URL for GBP review ingestion API (dev/test only)
# GBP_API_BASE_OVERRIDE=

# ─── ContentFlow / Repurposer ───────────────────────────────────
# Enable Facebook Insights collection for ContentFlow (optional, default: off)
# CONTENTFLOW_FB_INSIGHTS=1
# Enable Instagram Insights collection for ContentFlow (optional, default: off)
# CONTENTFLOW_IG_INSIGHTS=1

# Stub AI calls in the repurposer (dev/test only, default: off)
# REPURPOSER_AI_STUB=1
# Auto-fire repurposer on article approval (optional, default: off)
# REPURPOSER_AUTO_FIRE=1

# ─── Email / Charts ─────────────────────────────────────────────
# Directory for chart image files used in report emails (optional)
# EMAIL_CHARTS_DIR=./data/email-charts
# Simulate success for email sends in test/dev (dev only, default: off)
# EMAIL_TEST_SIMULATE_SUCCESS=1

# ─── Cloudflare R2 Storage (optional) ───────────────────────────
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ─── Third-party Integrations (optional) ────────────────────────
# SERPER_API_KEY=your_serper_key
# OUTSCRAPER_API_KEY=your_outscraper_key
# DATAFORSEO_LOGIN=your_login
# DATAFORSEO_PASSWORD=your_password
# INSTANTLY_API_KEY=your_instantly_key
# SMARTLEAD_API_KEY=your_smartlead_key
# QUICKCHART_API_KEY=your_quickchart_key

# ─── Multi-provider SERP orchestrator (Wave 6.5) ────────────────
# Rotates SERP requests across 6 providers, free-tier-first ($0 upfront,
# 5500+ free queries/month combined). Any provider with its env var
# missing is silently skipped — set whichever you have.
#
# Provider order per engine:
#   google_web      : googleCse → serper → brave → scaleserp → serpstack → dataforseo
#   google_maps     : serper → scaleserp → dataforseo
#   bing_equivalent : brave → dataforseo  (Bing v7 deprecated Aug 2025)
#
# Google Custom Search (100/day FREE, then $5/1k)
# GOOGLE_CUSTOMSEARCH_API_KEY=your_google_cse_api_key
# GOOGLE_CUSTOMSEARCH_CX=your_programmable_search_engine_id
# Brave Search API (2000/mo FREE on Data for Search plan, card on file)
# BRAVE_SEARCH_API_KEY=your_brave_search_key
# ScaleSerp (100/mo FREE)
# SCALESERP_API_KEY=your_scaleserp_key
# SerpStack (100/mo FREE, free tier is HTTP only — see provider file)
# SERPSTACK_API_KEY=your_serpstack_key
# DATAFORSEO_LOGIN / DATAFORSEO_PASSWORD already documented above
# (pay-as-you-go fallback ~$0.001/call, $25 minimum top-up).

# ─── QuoteQuick Hosting ──────────────────────────────────────────
# Domain used for hosted calculator subdomains (default: instant-quote.com)
# QQ_HOSTING_DOMAIN=instant-quote.com
# Same value exposed to the Vite client build
# VITE_QQ_HOSTING_DOMAIN=instant-quote.com

# ─── Security / Tokens (optional) ───────────────────────────────
# TOKEN_ENCRYPTION_KEY is defined in the Google Cloud section above.
# UNSUBSCRIBE_SECRET=random-secret
# BILLING_PORTAL_SECRET=random-secret
# OUTREACH_WEBHOOK_SECRET=random-secret
# QQP_WEBHOOK_SECRET=random-secret

# ─── Slack Alerts (optional) ─────────────────────────────────────
# SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# ─── Internal / Dev-only ────────────────────────────────────────
# ADMIN_EMAIL=admin@yourdomain.com
# INTERNAL_LEAD_EMAIL=leads@yourdomain.com
# MAPGUARD_ALERT_EMAIL=alerts@yourdomain.com
# SOCIALSYNC_ALERT_EMAIL=alerts@yourdomain.com
# TEST_ADMIN_EMAIL=test@example.com
# TEST_ADMIN_PASSWORD=test_password
# DEV_TOOLS_ENABLED=true
# ADMIN_TOOLS_ENABLED=true

# ─── Sentry APM (optional) ──────────────────────────────────────
# Server-side Sentry DSN for error tracking and performance monitoring
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Client-side Sentry DSN (exposed to browser via Vite)
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── Replit (auto-injected, do not set manually) ───────────────
# REPL_ID is set automatically by the Replit environment
# REPL_ID=
# REPLIT_DEV_DOMAIN is used for URL generation when running on Replit
# REPLIT_DEV_DOMAIN=

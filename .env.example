# ─── Core / Server ───────────────────────────────────────────────
# Node environment: development | production
NODE_ENV=development

# Port the server listens on (default 5000)
# PORT=5000

# Session secret for express-session (REQUIRED in production)
SESSION_SECRET=change-me-to-a-random-string

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/wefixtrades

# Public-facing app URL (used in emails, redirects, billing portal links)
# APP_URL=https://yourdomain.com

# Public-facing URL used for asset links, email images, media URLs
# Falls back to APP_URL when not set (optional)
# APP_PUBLIC_URL=https://yourdomain.com

# Base URL for test scripts (test-stripe-flow, test-tradeline-flow)
# BASE_URL=http://localhost:5000

# Log level: debug | info (optional)
# LOG_LEVEL=info

# ─── AI / LLM ───────────────────────────────────────────────────
# Anthropic Claude API key (primary AI — audit reports, chat, etc.)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model override (optional — defaults to claude-haiku-4-5-20251001)
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# OpenAI API key (for AI-powered pricing generation)
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key_here

# OpenAI base URL override (optional — for proxies or compatible endpoints)
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# OpenAI API key (secondary — image generation, etc.)
# OPENAI_API_KEY=your_openai_api_key_here

# ─── Image Generation (OpenAI) ─────────────────────────────────────
# Model for AI image generation (optional, default: gpt-image-1)
# IMAGE_MODEL=gpt-image-1
# Image quality: low | medium | high (optional, default: medium)
# IMAGE_QUALITY=medium
# Image size: 1024x1024 | 1024x1536 | 1536x1024 (optional, default: 1024x1024)
# IMAGE_SIZE=1024x1024
# Override base URL for image generation API (dev/test only)
# IMAGE_API_BASE_OVERRIDE=

# ─── Stripe (Payments) ──────────────────────────────────────────
# Stripe secret key (REQUIRED — used across billing, checkout, subscriptions)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe webhook signing secrets (REQUIRED in production)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_BILLING_WEBHOOK_SECRET=whsec_your_billing_webhook_secret_here

# Stripe Price IDs for QuoteQuick plans
STRIPE_PRICE_QQ_SOLO_MONTHLY=price_xxx
STRIPE_PRICE_QQ_SOLO_ANNUAL=price_xxx
STRIPE_PRICE_QQ_BUSINESS_MONTHLY=price_xxx
STRIPE_PRICE_QQ_BUSINESS_ANNUAL=price_xxx

# ─── Twilio (SMS / WhatsApp) ────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# Legacy alias (some code references TWILIO_PHONE_NUMBER)
# TWILIO_PHONE_NUMBER=+1234567890

# ─── SMTP (Email) ───────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# ─── Google APIs ─────────────────────────────────────────────────
# Google Maps Places API key (for business search + place details)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google PageSpeed Insights API key (for website speed analysis)
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# Google Business Profile OAuth (optional)
# GOOGLE_BUSINESS_CLIENT_ID=
# GOOGLE_BUSINESS_CLIENT_SECRET=
# GOOGLE_BUSINESS_REDIRECT_URI=

# Google OAuth (optional — generic OAuth)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=

# ─── Vapi Voice Integration (optional) ──────────────────────────
# VAPI_API_KEY=your_vapi_api_key_here
# VAPI_PUBLIC_KEY=your_vapi_public_key_here
# VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
# VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here
# VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here
# VAPI_SERVER_URL=https://yourdomain.com
# VAPI_WFT_VOICE_ID=your_voice_id_here

# ─── Facebook / Instagram (optional) ────────────────────────────
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# FACEBOOK_REDIRECT_URI=

# ─── SocialSync ─────────────────────────────────────────────────
# Webhook URL for SocialSync alerts (Slack/Discord/etc.) (optional)
# SOCIALSYNC_ALERT_WEBHOOK=https://hooks.slack.com/services/xxx

# Local directory for SocialSync media files (optional, has built-in default)
# SOCIALSYNC_MEDIA_DIR=./data/socialsync-media

# Override base URL for Facebook Graph API (dev/test only)
# FB_GRAPH_API_BASE_OVERRIDE=
# Override base URL for Instagram Graph API (dev/test only)
# IG_GRAPH_API_BASE_OVERRIDE=
# Override base URL for Google Business Profile posting API (dev/test only)
# GBP_POST_API_BASE_OVERRIDE=
# Override base URL for GBP review ingestion API (dev/test only)
# GBP_API_BASE_OVERRIDE=

# ─── ContentFlow / Repurposer ───────────────────────────────────
# Enable Facebook Insights collection for ContentFlow (optional, default: off)
# CONTENTFLOW_FB_INSIGHTS=1
# Enable Instagram Insights collection for ContentFlow (optional, default: off)
# CONTENTFLOW_IG_INSIGHTS=1

# Stub AI calls in the repurposer (dev/test only, default: off)
# REPURPOSER_AI_STUB=1
# Auto-fire repurposer on article approval (optional, default: off)
# REPURPOSER_AUTO_FIRE=1

# ─── Email / Charts ─────────────────────────────────────────────
# Directory for chart image files used in report emails (optional)
# EMAIL_CHARTS_DIR=./data/email-charts
# Simulate success for email sends in test/dev (dev only, default: off)
# EMAIL_TEST_SIMULATE_SUCCESS=1

# ─── Cloudflare R2 Storage (optional) ───────────────────────────
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# ─── Third-party Integrations (optional) ────────────────────────
# SERPER_API_KEY=your_serper_key
# OUTSCRAPER_API_KEY=your_outscraper_key
# DATAFORSEO_LOGIN=your_login
# DATAFORSEO_PASSWORD=your_password
# INSTANTLY_API_KEY=your_instantly_key
# SMARTLEAD_API_KEY=your_smartlead_key
# QUICKCHART_API_KEY=your_quickchart_key

# ─── Security / Tokens (optional) ───────────────────────────────
# AES-256-GCM key for encrypting OAuth tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — without it, token storage is refused.
# TOKEN_ENCRYPTION_KEY=your-64-hex-char-key-here
# UNSUBSCRIBE_SECRET=random-secret
# BILLING_PORTAL_SECRET=random-secret
# OUTREACH_WEBHOOK_SECRET=random-secret
# QQP_WEBHOOK_SECRET=random-secret

# ─── Internal / Dev-only ────────────────────────────────────────
# ADMIN_EMAIL=admin@yourdomain.com
# INTERNAL_LEAD_EMAIL=leads@yourdomain.com
# MAPGUARD_ALERT_EMAIL=alerts@yourdomain.com
# SOCIALSYNC_ALERT_EMAIL=alerts@yourdomain.com
# TEST_ADMIN_EMAIL=test@example.com
# TEST_ADMIN_PASSWORD=test_password
# DEV_TOOLS_ENABLED=true
# ADMIN_TOOLS_ENABLED=true

# ─── Replit (auto-injected, do not set manually) ───────────────
# REPL_ID is set automatically by the Replit environment
# REPL_ID=
# REPLIT_DEV_DOMAIN is used for URL generation when running on Replit
# REPLIT_DEV_DOMAIN=

modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["unzip", "lsof"]

[[ports]]
localPort = 3000
externalPort = 6000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 9323
externalPort = 5173

[[ports]]
localPort = 13759
externalPort = 3003
exposeLocalhost = true

[[ports]]
localPort = 13867
externalPort = 4200
exposeLocalhost = true

[[ports]]
localPort = 23264
externalPort = 6800
exposeLocalhost = true

[[ports]]
localPort = 31026
externalPort = 5000
exposeLocalhost = true

[[ports]]
localPort = 31093
externalPort = 3000
exposeLocalhost = true

[[ports]]
localPort = 31503
externalPort = 3002
exposeLocalhost = true

[[ports]]
localPort = 63329
externalPort = 3001
exposeLocalhost = true

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "./scripts/start-prod.sh"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

# NOTE: `javascript_database:1.0.0` was deliberately REMOVED from the
# integrations list. That integration causes Replit's deploy pipeline to
# auto-run schema-sync (Drizzle Kit) against the production database on every
# Publish, which surfaces the destructive-migration approval prompt Alex sees.
# The project applies SQL via server/lib/bootstrapMigrations.ts at boot, not
# via the dev-only schema-sync flow, so the integration is unnecessary AND
# unsafe. Do NOT re-add it without first ripping `bootstrapMigrations()` out
# of server/index.ts and consciously moving prod schema management onto Replit.
[agent]
integrations = ["javascript_openai_ai_integrations:2.0.0", "javascript_auth_all_persistance:1.0.0", "javascript_stripe:1.0.0"]
expertMode = true

[userenv]

[userenv.shared]
